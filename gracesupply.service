[Unit]
Description=GraceSupply Alpha
After=network.target

[Service]
User=christi
WorkingDirectory=/opt/gracesupply
EnvironmentFile=/opt/gracesupply/.env
Environment="PATH=/opt/gracesupply/.venv/bin"
ExecStart=/opt/gracesupply/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5050 run:app
Restart=always

[Install]
WantedBy=multi-user.target
