[Unit]
Description=GraceSupply Alpha
After=network.target

[Service]
User=REPLACE_WITH_YOUR_USER
WorkingDirectory=/opt/gracesupply
Environment="PATH=/opt/gracesupply/.venv/bin"
ExecStart=/opt/gracesupply/.venv/bin/gunicorn -w 2 -b 0.0.0.0:5050 run:app
Restart=always

[Install]
WantedBy=multi-user.target
